# Copy this file outside the repository, replace every placeholder, and pass it
# with --config or MIGRATION_CONFIG. Every setting is required; there are no
# machine-, account-, or dataset-specific defaults.
PCM_BASE_DIR=/path/on/persistent-volume/pcloud-proton-migration
PCM_STAGING_DIR=/path/on/persistent-volume/pcloud-proton-migration/stage
PCM_STORAGE_MOUNT=/path/on/persistent-volume
PCM_REQUIRE_MOUNTPOINT=true

PCM_SOURCE_REMOTE=pcloud-source:
PCM_SOURCE_ROOT=/
PCM_EXPECTED_PCLOUD_ACCOUNT=replace-with-local-account-assertion
PCM_ACCOUNT_FINGERPRINT_KEY_FILE=/etc/pcloud-proton-migrate/account-fingerprint.key
PCM_DESTINATION_ROOT=/destination-root
PCM_EXPECTED_PROTON_ACCOUNT=replace-with-local-account-assertion
PCM_PROTON_CLI_EXPECTED_VERSION=replace-with-exact-proton-cli-version
# Set true only after independently confirming that the destination has enough
# capacity. When Proton reports usable quota, the controller checks it instead.
PCM_DESTINATION_CAPACITY_ACKNOWLEDGED=false
PCM_RCLONE_CONFIG=/path/to/rclone.conf
PCM_PROTON_RUNNER=/path/to/proton-drive-runner
PCM_PROTON_BIN=/path/to/proton-drive
PCM_RUNTIME_USER=pcloud-proton

# The start/doctor gates require both reserves to be available.
PCM_MIN_FREE_BYTES=10737418240
PCM_MIN_FREE_INODES=100000

# Conservative bounded concurrency. Increase only after measuring errors and
# aggregate throughput; all values are range-checked by config validation.
PCM_INVENTORY_WORKERS=8
PCM_CHECKSUM_WORKERS=16
PCM_DOWNLOAD_TRANSFERS=8
PCM_DOWNLOAD_CHECKERS=16
PCM_MULTI_THREAD_STREAMS=2
PCM_LOCAL_VERIFY_WORKERS=8
PCM_UPLOAD_WORKERS=8
PCM_DESTINATION_VERIFY_WORKERS=8

PCM_RCLONE_RETRIES=5
PCM_RCLONE_LOW_LEVEL_RETRIES=10
PCM_RETRY_SLEEP=30s
PCM_MAX_PHASE_ATTEMPTS=3
PCM_PROGRESS_INTERVAL=30s

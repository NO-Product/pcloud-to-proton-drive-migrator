#!/usr/bin/env bash
set -Eeuo pipefail
state=${FAKE_PROTON_STATE:?FAKE_PROTON_STATE is required}
if [ "${1:-}" = --version ]; then printf '%s\n' "${FAKE_PROTON_VERSION:-1.0.0}"; exit 0; fi
case "${1:-} ${2:-}" in
  "account login") install -d -m 0700 "$(dirname "$state")"; : > "$state";;
  "account info")
    [ -f "$state" ] || { printf 'authentication required\n' >&2; exit 1; }
    printf '{"account":"%s","account_id":"fake-account-id","used_bytes":%s,"quota_bytes":%s}\n' \
      "${FAKE_PROTON_ACCOUNT:-fixture@example.invalid}" "${FAKE_PROTON_USED_BYTES:-0}" "${FAKE_PROTON_QUOTA_BYTES:-1099511627776}"
    ;;
  "account logout") rm -f -- "$state";;
  *) [ -f "$state" ] || { printf 'authentication required\n' >&2; exit 1; }; printf '%s\n' "$*";;
esac
